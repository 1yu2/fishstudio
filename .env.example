# 项目根 .env：docker compose 启动时读取（区别于 backend/.env）
#
# 复制：cp .env.example .env  并填生产值

# ─── 通用 ────────────────────────────────────────────────────────
LOG_LEVEL=INFO
BASE_URL=http://localhost:8007

# ─── 端口（按需改）───────────────────────────────────────────────
# BACKEND_PORT 避开 8000（被 Resume-Matcher 等其他项目占用），用 8007
FRONTEND_PORT=3000
BACKEND_PORT=8007
POSTGRES_PORT=5432

# ─── 本地 PG 容器（仅 docker-compose.yml 用到，prod override 会跳过）──
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fishstudio

# ─── 认证（生产务必改）───────────────────────────────────────────
JWT_SECRET=please-change-me-to-a-long-random-string-min-16-chars
JWT_EXPIRE_MINUTES=10080
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin1234

# ─── CORS 白名单（生产改成实际域名）──────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost

# ─── 仅生产 prod override 用到：宿主机 PG 凭据 ─────────────────
# HOST_PG_USER=postgres
# HOST_PG_PASSWORD=ffkj1314
# HOST_PG_PORT=5432
# HOST_PG_DB=fishstudio
